std = "lua51"
globals = {
    "require",
    "assert",
    "error",
    "ipairs",
    "pairs",
    "pcall",
    "print",
    "tonumber",
    "tostring",
    "type",
    "os",
    "io",
    "table",
    "string",
    "math",
    "setmetatable",
    "getmetatable",
    "rawget",
    "rawset",
    "_G",
    "_",
}
max_line_length = 140
ignore = {
    "212", -- unused argument
    "213", -- unused variable
}
